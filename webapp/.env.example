# Path to the knowledge-base repo root. Defaults to the parent folder of webapp/.
# KB_PATH=

# --- Write path (new-card wizard -> GitHub PR). Optional: without these the
# wizard still works, offering download/copy instead of opening a PR. ---
# Fine-grained PAT with Contents: read/write + Pull requests: read/write on the repo
# GITHUB_TOKEN=
# GITHUB_REPO=yzyzieee/Literature_ANC_Database
# GITHUB_BASE=main

# --- LLM provider (drafting + PDF extraction). Switch provider by setting
# LLM_PROVIDER and the matching key — no code change. DeepSeek is the default
# and is text-only; gemini/openai/anthropic are vision-capable (better for
# figures/equations) and are pre-wired, just add a key. ---
# LLM_PROVIDER=deepseek            # deepseek | gemini | openai | anthropic
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-pro   # or deepseek-v4-flash (cheaper)
# GEMINI_API_KEY=                  # Google AI Studio key
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Shown in the UI for linking to the repo / PR list (optional) ---
# NEXT_PUBLIC_GITHUB_REPO=yzyzieee/Literature_ANC_Database

# Shared Google Drive folder where PDFs are stored. Shown as an "Open shared
# Drive folder" link in the new-card wizard so submitters can drop the PDF in.
# NEXT_PUBLIC_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/XXXX

# --- In-app Drive upload via a service account (no per-user sign-in) ---
# When configured, the wizard shows an "Upload to Drive" button: the server
# starts a resumable session with the service account, the browser uploads the
# bytes straight to Google (no size limit), and the Drive link auto-fills.
# Setup (once): create a service account in Google Cloud, enable the Drive API,
# download its JSON key, and share the target folder (or a Shared Drive) with
# the service account's email as Editor.
#   GOOGLE_SERVICE_ACCOUNT_KEY = the entire service-account JSON, on one line
#   DRIVE_FOLDER_ID            = the folder id from the shared folder's URL
#   NEXT_PUBLIC_DRIVE_UPLOAD=1 = turns the upload button on in the UI
# GOOGLE_SERVICE_ACCOUNT_KEY=
# DRIVE_FOLDER_ID=
# NEXT_PUBLIC_DRIVE_UPLOAD=1

# --- Team access control (optional) ---
# Set a shared password to gate the whole site behind a login page. Leave unset
# for open access. Share this password with teammates who should be able to
# browse and submit. Changing it signs everyone out.
# APP_PASSWORD=
