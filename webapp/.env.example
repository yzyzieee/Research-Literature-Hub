# Optional path to the repository root. The default is the parent of webapp/.
# KB_PATH=C:\path\to\research-literature-hub

# GitHub-backed literature records, ratings, comments, and team registry.
# Use a fine-grained token limited to this repository with Contents read/write.
GITHUB_TOKEN=github_pat_REPLACE_ME
GITHUB_REPO=your-org/research-literature-hub
GITHUB_BASE=main
NEXT_PUBLIC_GITHUB_REPO=your-org/research-literature-hub

# Team sessions. Generate a long random value and keep it server-side.
AUTH_SECRET=replace-with-a-long-random-secret
# Comma-separated account IDs permitted to sign in. Defaults to YZY.
LOGIN_ALLOWED_ACCOUNTS=YZY

# Optional LLM extraction. Set one provider and its matching key.
LLM_PROVIDER=gemini
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-flash-lite
# DEEPSEEK_API_KEY=replace-me
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_API_KEY=replace-me
# OPENAI_MODEL=gpt-4.1-mini
# ANTHROPIC_API_KEY=replace-me
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Google Drive storage adapter.
DRIVE_FOLDER_ID=replace-with-folder-id
NEXT_PUBLIC_DRIVE_UPLOAD=1
NEXT_PUBLIC_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/REPLACE_ME

# Choose exactly one Drive authentication method.
#
# A. Owner OAuth for a personal or Workspace Drive:
# GOOGLE_OAUTH_CLIENT_ID=replace-me.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=replace-me
# GOOGLE_OAUTH_REFRESH_TOKEN=replace-me
#
# B. Service account for an appropriately shared Workspace location:
# Store the complete one-line JSON object as the environment variable value.
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"replace-me"}
