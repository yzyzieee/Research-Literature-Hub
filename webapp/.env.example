# Path to the knowledge-base repo root. Defaults to the parent folder of webapp/.
# KB_PATH=

# --- GitHub-backed cards, ratings, and team registry ---
# Fine-grained PAT with Contents: read/write on the repo.
# GITHUB_TOKEN=
# GITHUB_REPO=yzyzieee/Literature_ANC_Database
# GITHUB_BASE=main

# --- LLM provider (drafting + PDF extraction). Switch provider by setting
# LLM_PROVIDER and the matching key — no code change. DeepSeek is the default
# and is text-only; gemini/openai/anthropic are vision-capable (better for
# figures/equations) and are pre-wired, just add a key. ---
# LLM_PROVIDER=deepseek            # deepseek | gemini | openai | anthropic
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-pro   # or deepseek-v4-flash (cheaper)
# GEMINI_API_KEY=                  # Google AI Studio key
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Shown in the UI for linking to the repo / PR list (optional) ---
# NEXT_PUBLIC_GITHUB_REPO=yzyzieee/Literature_ANC_Database

# Shared Google Drive folder where PDFs are stored. Shown as an "Open shared
# Drive folder" link in the new-card wizard so submitters can drop the PDF in.
# NEXT_PUBLIC_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/XXXX

# --- In-app Drive upload (no per-user sign-in) ---
# The wizard shows an "Upload to Drive" button: the server starts a resumable
# session, the browser uploads the bytes straight to Google (no size limit),
# and the Drive link auto-fills. NEXT_PUBLIC_DRIVE_UPLOAD=1 turns the button on;
# DRIVE_FOLDER_ID is the id from the target folder's URL.
#
# Pick ONE auth method:
#
# (A) Owner OAuth — works on a personal Gmail Drive. You authorize once and the
#     app uploads as you into your folder; classmates never sign in. Get a
#     refresh token via the Google OAuth Playground with the drive.file scope
#     (publish the consent screen to Production so the token doesn't expire).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
#
# (B) Service account — Google Workspace only; the target must be a Shared
#     Drive (service accounts have no personal-Drive storage). Share the Shared
#     Drive with the service account email as Content manager.
# GOOGLE_SERVICE_ACCOUNT_KEY=
#
# DRIVE_FOLDER_ID=
# NEXT_PUBLIC_DRIVE_UPLOAD=1

# --- Team sessions ---
# Long random server-only value used to sign account cookies. Members choose
# their account name on the login page; they never enter this value. Changing
# it signs everyone out. APP_PASSWORD remains a backwards-compatible fallback.
# AUTH_SECRET=
